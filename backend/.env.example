# Copy this file to .env and fill in your actual values

PORT=5000

# MongoDB Atlas connection string
# All data (including images as base64 data URLs) is stored directly in MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/locallie?retryWrites=true&w=majority

# Deployed Frontend URL (optional, for explicit CORS whitelisting in production)
FRONTEND_URL=https://locallie.vercel.app
